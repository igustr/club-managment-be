<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <!--
        Added the constraints for entity Member.
    -->
    <changeSet id="20260304100004-2" author="clubmanagement">

        <addForeignKeyConstraint baseColumnNames="user_id"
                                 baseTableName="member"
                                 constraintName="fk_member__user_id"
                                 referencedColumnNames="id"
                                 referencedTableName="users"/>

        <addForeignKeyConstraint baseColumnNames="club_id"
                                 baseTableName="member"
                                 constraintName="fk_member__club_id"
                                 referencedColumnNames="id"
                                 referencedTableName="club"/>

        <addForeignKeyConstraint baseColumnNames="parent_id"
                                 baseTableName="member"
                                 constraintName="fk_member__parent_id"
                                 referencedColumnNames="id"
                                 referencedTableName="users"/>
    </changeSet>

</databaseChangeLog>
