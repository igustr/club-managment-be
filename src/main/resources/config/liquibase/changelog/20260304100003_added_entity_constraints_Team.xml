        <addForeignKeyConstraint baseColumnNames="coach_id"
                                 baseTableName="team"
                                 constraintName="fk_team__coach_id"
                                 referencedColumnNames="id"
                                 referencedTableName="users"/>
    </changeSet>

</databaseChangeLog>
