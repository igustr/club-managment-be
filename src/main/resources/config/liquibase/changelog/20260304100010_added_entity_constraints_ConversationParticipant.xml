<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <!--
        Added the constraints for entity ConversationParticipant.
    -->
    <changeSet id="20260304100010-2" author="clubmanagement">

        <addForeignKeyConstraint baseColumnNames="conversation_id"
                                 baseTableName="conversation_participant"
                                 constraintName="fk_conversation_participant__conversation_id"
                                 referencedColumnNames="id"
                                 referencedTableName="conversation"/>

        <addForeignKeyConstraint baseColumnNames="user_id"
                                 baseTableName="conversation_participant"
                                 constraintName="fk_conversation_participant__user_id"
                                 referencedColumnNames="id"
                                 referencedTableName="users"/>
    </changeSet>

</databaseChangeLog>
