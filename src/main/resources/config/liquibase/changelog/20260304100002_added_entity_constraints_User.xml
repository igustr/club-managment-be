<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <!--
        Added the constraints for entity User.
    -->
    <changeSet id="20260304100002-2" author="clubmanagement">

        <addForeignKeyConstraint baseColumnNames="club_id"
                                 baseTableName="users"
                                 constraintName="fk_users__club_id"
                                 referencedColumnNames="id"
                                 referencedTableName="club"/>

        <addForeignKeyConstraint baseColumnNames="child_id"
                                 baseTableName="user_parent"
                                 constraintName="fk_user_parent__child_id"
                                 referencedColumnNames="id"
                                 referencedTableName="users"/>

        <addForeignKeyConstraint baseColumnNames="parent_id"
                                 baseTableName="user_parent"
                                 constraintName="fk_user_parent__parent_id"
                                 referencedColumnNames="id"
                                 referencedTableName="users"/>
    </changeSet>

</databaseChangeLog>
