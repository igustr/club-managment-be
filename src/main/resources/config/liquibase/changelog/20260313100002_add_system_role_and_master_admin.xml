<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <!--
        Add system_role column to users table for platform-level roles.
    -->
    <changeSet id="20260313100002-1" author="clubmanagement">
        <addColumn tableName="users">
            <column name="system_role" type="varchar(20)"/>
        </addColumn>
    </changeSet>

    <!--
        Seed master admin user for platform management.
        Email: master@admin.ee / Password: admin
    -->
    <changeSet id="20260313100002-2" author="clubmanagement">
        <insert tableName="users">
            <column name="id" valueComputed="gen_random_uuid()"/>
            <column name="email" value="master@admin.ee"/>
            <column name="password_hash" value="$2b$12$64gxN6McXNrI6Z5/vEguyedaH5M5tXsPkblnOyQbEUUs4Pi/OvIK2"/>
            <column name="first_name" value="Master"/>
            <column name="last_name" value="Admin"/>
            <column name="date_of_birth" value="1990-01-01"/>
            <column name="phone" value="+372 5550000"/>
            <column name="system_role" value="MASTER_ADMIN"/>
            <column name="active" valueBoolean="true"/>
            <column name="created_by" value="system"/>
            <column name="created_date" valueComputed="current_timestamp"/>
            <column name="last_modified_by" value="system"/>
            <column name="last_modified_date" valueComputed="current_timestamp"/>
        </insert>
    </changeSet>

</databaseChangeLog>
