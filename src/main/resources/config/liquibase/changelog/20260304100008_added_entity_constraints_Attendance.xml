<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <!--
        Added the constraints for entity Attendance.
    -->
    <changeSet id="20260304100008-2" author="clubmanagement">

        <addForeignKeyConstraint baseColumnNames="training_session_id"
                                 baseTableName="attendance"
                                 constraintName="fk_attendance__training_session_id"
                                 referencedColumnNames="id"
                                 referencedTableName="training_session"/>

        <addForeignKeyConstraint baseColumnNames="member_id"
                                 baseTableName="attendance"
                                 constraintName="fk_attendance__member_id"
                                 referencedColumnNames="id"
                                 referencedTableName="member"/>

        <addForeignKeyConstraint baseColumnNames="confirmed_by_user_id"
                                 baseTableName="attendance"
                                 constraintName="fk_attendance__confirmed_by_user_id"
                                 referencedColumnNames="id"
                                 referencedTableName="users"/>
    </changeSet>

</databaseChangeLog>
